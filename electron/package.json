
{
  "name": "vocalflows",
  "version": "1.0.0",
  "main": "main.js",
  "scripts": {
    "dev": "electron .",
    "build-frontend": "cd ../frontend && npm run build",
    "pack": "npm run build-frontend && electron-builder --win"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",

  "build": {
    "appId": "com.vocalflows.app",
    "productName": "VocalFlows",
    "win": {
      "target": "nsis"
    },
    "files": ["main.js"],
    "extraResources": [
      { "from": "../frontend/dist", "to": "frontend/dist" },
      { "from": "../backend", "to": "backend", "filter": ["**/*", "!node_modules"] }
    ]
  },
  "devDependencies": {
    "electron": "^latest",
    "electron-builder": "^latest"
  }
}